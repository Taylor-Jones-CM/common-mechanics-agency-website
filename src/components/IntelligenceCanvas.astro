<canvas id="intelligence-canvas" aria-hidden="true"></canvas>

<style>
  #intelligence-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    opacity: 0.4;
  }
</style>

<script>
  const canvas = document.getElementById('intelligence-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  // Seeded PRNG (mulberry32) — deterministic layout on every render
  function mulberry32(seed: number) {
    return function () {
      seed |= 0;
      seed = (seed + 0x6d2b79f5) | 0;
      let t = Math.imul(seed ^ (seed >>> 15), 1 | seed);
      t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  interface Line {
    startX: number;
    startY: number;
    endX: number;
    endY: number;
    opacity: number;
    depth: number;
  }

  const rand = mulberry32(42);
  const LINES: Line[] = [];
  const LINE_COUNT = 90;
  const BRANCH_PROB = 0.42;
  const MAX_DEPTH = 2;

  let W = 0, H = 0, cx = 0, cy = 0;
  let phase = 0;
  let dpr = 1;
  let animating = true;

  function buildLine(startX: number, startY: number, angle: number, depth: number) {
    const minDim = Math.min(W, H);
    const maxLen =
      depth === 0
        ? minDim * 0.15 + rand() * minDim * 0.32
        : minDim * 0.05 + rand() * minDim * 0.12;

    const endX = startX + Math.cos(angle) * maxLen;
    const endY = startY + Math.sin(angle) * maxLen;
    const opacity =
      depth === 0
        ? 0.10 + rand() * 0.20
        : 0.05 + rand() * 0.10;

    LINES.push({ startX, startY, endX, endY, opacity, depth });

    if (depth < MAX_DEPTH) {
      const branchChance = depth === 0 ? BRANCH_PROB : BRANCH_PROB * 0.45;
      if (rand() < branchChance) {
        const t = 0.38 + rand() * 0.52;
        const bx = startX + (endX - startX) * t;
        const by = startY + (endY - startY) * t;
        const spread = Math.PI / 6 + rand() * (Math.PI / 4);
        const side = rand() > 0.5 ? 1 : -1;
        buildLine(bx, by, angle + side * spread, depth + 1);
      }
    }
  }

  function buildLines() {
    LINES.length = 0;
    // Re-seed so resize always produces the same layout
    const r = mulberry32(42);
    for (let i = 0; i < LINE_COUNT; i++) {
      buildLine(cx, cy, r() * Math.PI * 2, 0);
    }
  }

  function resize() {
    dpr = window.devicePixelRatio || 1;
    W = window.innerWidth;
    H = window.innerHeight;
    canvas.width = W * dpr;
    canvas.height = H * dpr;
    canvas.style.width = W + 'px';
    canvas.style.height = H + 'px';
    ctx.scale(dpr, dpr);
    cx = W * 0.42;
    cy = H * 0.38;
    buildLines();
  }

  function draw() {
    if (!animating) return;

    ctx.clearRect(0, 0, W, H);

    phase += 0.0018;
    const pulse = 0.72 + Math.sin(phase) * 0.28;

    for (const line of LINES) {
      const alpha = line.opacity * pulse;
      ctx.beginPath();
      ctx.moveTo(line.startX, line.startY);
      ctx.lineTo(line.endX, line.endY);
      ctx.strokeStyle = `rgba(226, 226, 226, ${alpha.toFixed(3)})`;
      ctx.lineWidth = line.depth === 0 ? 0.5 : 0.28;
      ctx.stroke();
    }

    requestAnimationFrame(draw);
  }

  // Pause when tab is not visible
  document.addEventListener('visibilitychange', () => {
    animating = !document.hidden;
    if (animating) requestAnimationFrame(draw);
  });

  window.addEventListener('resize', resize, { passive: true });

  resize();
  requestAnimationFrame(draw);
</script>
