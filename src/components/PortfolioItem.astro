---
interface Props {
  title: string;
  url: string;
  year: number;
  roles: string[];
  team: string[];
  preview: string;
}

const { title, url, year, roles, team, preview } = Astro.props;
const rolesStr = roles.join(' / ');
const teamStr = team.join(', ');
---

<li class="portfolio-item">
  <div class="portfolio-left">
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="portfolio-link"
      data-preview={preview}
      aria-label={`${title} — ${rolesStr}`}
    >
      <span class="portfolio-title">{title}</span>
    </a>
    <span class="meta-year">{year}</span>
  </div>
  <span class="portfolio-meta">
    <span class="meta-team">{teamStr}</span>
    <span class="meta-roles">{rolesStr}</span>
  </span>
</li>

<style>
  .portfolio-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-accent-line);
  }

  .portfolio-item:first-child {
    border-top: 1px solid var(--color-accent-line);
  }

  /* Left side: title + year together, wrapping if needed */
  .portfolio-left {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    flex-shrink: 1;
    min-width: 0;
  }

  .portfolio-link {
    text-decoration: none;
    flex-shrink: 1;
    min-width: 0;
  }

  .portfolio-link:hover .portfolio-title {
    text-decoration: underline;
    text-decoration-color: var(--color-fg);
    text-underline-offset: 3px;
  }

  .portfolio-title {
    font-size: var(--font-size-base);
  }

  /* Right side: team + roles, allowed to wrap */
  .portfolio-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-6);
    flex-shrink: 0;
    align-items: baseline;
    justify-content: flex-end;
    max-width: 50%;
  }

  .meta-year,
  .meta-team,
  .meta-roles {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  /* Wrap to stacked layout on narrow viewports */
  @media (max-width: 640px) {
    .portfolio-item {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-1);
    }

    .portfolio-meta {
      max-width: 100%;
      justify-content: flex-start;
    }
  }
</style>
