---

<section class="section">
  <div class="section-header">
    <span class="section-label">Work</span>
    <span class="section-desc">Including independent work from our team members</span>
  </div>
  <ul class="portfolio-list">
    {projects.map((project) => (
      <PortfolioItem
        title={project.title}
        url={project.url}
        year={project.year}
        roles={project.roles}
        team={project.team}
        preview={project.preview}
      />
    ))}
  </ul>
  <HoverPreview />
</section>

<style>
  .section-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .section-header .section-label {
    margin-bottom: 0;
    flex-shrink: 0;
  }

  .section-desc {
    font-size: var(--font-size-xs);
    color: var(--color-muted);
    letter-spacing: var(--tracking-wide);
  }

  .portfolio-list {
    list-style: none;
  }
</style>
